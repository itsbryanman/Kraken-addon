# ============================================================================
# KRAKEN ADDON - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and configure as needed

# Server Configuration
PORT=7000
HOST=0.0.0.0
BASE_URL=http://localhost:7000

# Node Environment (development | production)
NODE_ENV=development

# Logging Level (debug | info | warn | error)
LOG_LEVEL=info

# ============================================================================
# CACHING
# ============================================================================

# Redis URL (optional - if not set, uses in-memory cache)
# REDIS_URL=redis://localhost:6379

# Cache TTL in seconds
CACHE_STREAM_TTL=3600
CACHE_PROVIDER_TTL=1800
CACHE_DEBRID_TTL=28800

# ============================================================================
# DEBRID SERVICES (for testing/default config)
# ============================================================================

# Real-Debrid
# RD_API_KEY=your_api_key_here

# AllDebrid  
# AD_API_KEY=your_api_key_here

# Premiumize
# PM_API_KEY=your_api_key_here

# Debrid-Link
# DL_API_KEY=your_api_key_here

# TorBox
# TB_API_KEY=your_api_key_here

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================

# Prowlarr
# PROWLARR_URL=http://localhost:9696
# PROWLARR_API_KEY=your_api_key_here

# Jackett
# JACKETT_URL=http://localhost:9117
# JACKETT_API_KEY=your_api_key_here

# Zilean (DMM database)
# ZILEAN_URL=http://localhost:8181

# ============================================================================
# RATE LIMITING
# ============================================================================

# Maximum concurrent requests per provider
MAX_CONCURRENT_REQUESTS=5

# Default rate limit (requests per minute)
DEFAULT_RATE_LIMIT=30

# ============================================================================
# MONITORING (optional)
# ============================================================================

# Prometheus metrics endpoint
# METRICS_ENABLED=true
# METRICS_PORT=9091

# Grafana password (if using monitoring profile)
# GRAFANA_PASSWORD=admin

# ============================================================================
# SECURITY
# ============================================================================

# CORS allowed origins (comma-separated, * for all)
CORS_ORIGINS=*

# API rate limiting (requests per minute per IP)
API_RATE_LIMIT=100
